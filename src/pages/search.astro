---
import BaseLayout from '@platform/core/src/layouts/BaseLayout.astro'
import { getSiteConfig } from '@platform/core/src/lib/config'

const cfg = getSiteConfig()
---

<BaseLayout
  title={`Search — ${cfg.site.brand_name}`}
  description={`Search all product reviews and buying guides on ${cfg.site.brand_name}.`}
  noindex={true}
>
  <div class="container" style="padding: 3rem 1.5rem;">
    <h1>Search Reviews</h1>
    <div id="search" class="pagefind-search"></div>
  </div>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script>
  window.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore — pagefind loads at runtime after build
    new PagefindUI({ element: '#search', showSubResults: true })
  })
</script>
<script src="/pagefind/pagefind-ui.js" is:inline>

<style>
  .pagefind-search { margin-top: 1.5rem; }
</style>
