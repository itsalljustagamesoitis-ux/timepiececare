# Per-clone environment variables
# Copy to .env.local for local development.
# Set each of these in Cloudflare Pages → Settings → Environment Variables.

# Amazon Associates tracking tag (overrides site.config.yaml amazon_tracking_id)
AMAZON_TAG=yoursite-20

# Google Analytics 4 measurement ID (overrides site.config.yaml ga4_measurement_id)
GA4_ID=G-XXXXXXXXXX

# Site URL — used for canonical URLs and sitemap (overrides site.config.yaml domain)
SITE_URL=https://yourdomain.com

# Google Search Console verification (HTML tag method)
# Get from: GSC → Settings → Ownership verification → HTML tag → copy content= value
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification (HTML tag method)
# Get from: Bing Webmaster → Add site → HTML Meta Tag → copy content= value
BING_SITE_VERIFICATION=

# IndexNow key — auto-generated by scripts/clone-site.sh (32-char lowercase hex)
# The same value must exist as public/<key>.txt in the repo.
# Set as a Secret in Cloudflare Pages → Settings → Environment Variables.
INDEXNOW_KEY=
